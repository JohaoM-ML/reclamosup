# =============================================================================
# ReclamoUP — Supabase (PostgreSQL)
# =============================================================================
# 1. Crea un proyecto en https://supabase.com
# 2. Ve a: Project Settings → Database → Connection string
# 3. Copia las URLs y reemplaza [PASSWORD] y [PROJECT-REF]
# =============================================================================

# App en runtime (pooler, puerto 6543) — usar en Next.js / Vercel
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Migraciones y seed (conexión directa, puerto 5432)
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# Alternativa directa (sin pooler):
# DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# Auth (cookie JWT)
SESSION_SECRET="cambia-esto-por-un-secreto-largo-en-produccion"

# Supabase Storage (PDFs escaneados) — Project Settings → API
SUPABASE_URL="https://[PROJECT-REF].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ... (service_role — solo servidor, nunca en el cliente)"

# Chatbot estudiante (Anthropic) — https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL="claude-sonnet-4-5-20250929"

# Contraseña compartida de todos los usuarios (seed + npm run db:sync-passwords)
CONTRASENA_INICIAL="demo123"

# Correo (Resend) — https://resend.com/domains
RESEND_API_KEY="re_..."
EMAIL_FROM="ReclamoUP <notificaciones@mail.reclamoup.uk>"
# URL pública (enlaces en correos). En Vercel también funciona VERCEL_URL automáticamente.
APP_URL="https://www.reclamoup.uk"
# Opcional: redirige todos los correos (solo si no tienes dominio verificado)
# EMAIL_DEMO_TO="tu@gmail.com"
